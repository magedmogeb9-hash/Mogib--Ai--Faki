<!DOCTYPE html>
<html dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>Mythos Artifacts - معاينة التصميمات</title>
    <link rel="stylesheet" href="/static/style.css">
    <style>
        .artifact-container { display: flex; gap: 20px; margin: 20px; }
        .code-panel, .preview-panel { flex: 1; background: #161b22; border-radius: 12px; padding: 15px; }
        pre { background: #0d1117; padding: 10px; border-radius: 8px; overflow-x: auto; }
        iframe { width: 100%; height: 400px; border: none; background: white; }
        .toolbar { display: flex; gap: 10px; margin-bottom: 15px; }
        button { background: #238636; }
    </style>
</head>
<body>
<div class="container">
    <div class="sidebar">
        <h2>📦 Artifacts Designer</h2>
        <a href="/mythos">← Dashboard</a>
        <button id="newArtifactBtn">➕ إنشاء واجهة جديدة</button>
    </div>
    <div class="chat-area">
        <div class="artifact-container">
            <div class="code-panel">
                <h3>📄 Code (HTML/CSS/JS)</h3>
                <textarea id="codeEditor" rows="20" style="width:100%; background:#0d1117; color:white; font-family:monospace;"></textarea>
            </div>
            <div class="preview-panel">
                <h3>👁️ Preview</h3>
                <iframe id="previewFrame" srcdoc="<html><body style='background:#0d1117;color:white;'>معاينة التصميم ستظهر هنا</body></html>"></iframe>
            </div>
        </div>
    </div>
</div>
<script>
    const codeArea = document.getElementById('codeEditor');
    const preview = document.getElementById('previewFrame');
    function updatePreview() { preview.srcdoc = codeArea.value; }
    codeArea.addEventListener('input', updatePreview);
    document.getElementById('newArtifactBtn').onclick = async () => {
        const promptText = prompt("صف الواجهة التي تريد إنشاءها (مثال: 'لوحة تحكم لمراقبة الخوادم بوضع مظلم'):");
        if(!promptText) return;
        const res = await fetch('/api/chat', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ messages: [{role:'user', content: `قم بكتابة HTML و CSS و JavaScript لإنشاء: ${promptText}. أخرج الكود فقط بدون شرح.`}] })
        });
        const reader = res.body.getReader();
        let fullCode = '';
        while(true) {
            const {done, value} = await reader.read();
            if(done) break;
            const chunk = new TextDecoder().decode(value);
            const lines = chunk.split('\\n');
            for(let line of lines) {
                if(line.startsWith('data: ')) {
                    const data = line.slice(6);
                    if(data !== '[DONE]') {
                        try { const json = JSON.parse(data); fullCode += json.text; } catch(e) {}
                    }
                }
            }
        }
        codeArea.value = fullCode;
        updatePreview();
    };
</script>
</body>
</html>
```
