MYFATOORAH_MODE = os.getenv('MYFATOORAH_MODE', 'test')
MYFATOORAH_URL = 'https://apitest.myfatoorah.com' if MYFATOORAH_MODE == 'test' else 'https://api.myfatoorah.com'

def create_myfatoorah_invoice(amount, user_email, user_name, payment_id):
    headers = {'Authorization': f'Bearer {MYFATOORAH_API_KEY}', 'Content-Type': 'application/json'}
    data = {
        'CustomerName': user_name,
        'CustomerEmail': user_email,
        'InvoiceValue': amount,
        'DisplayCurrencyIso': 'USD',
        'CallBackUrl': f'http://localhost:5000/payment-callback?payment_id={payment_id}',
        'ErrorUrl': 'http://localhost:5000/payment-error',
        'Language': 'en'
    }
    response = requests.post(f'{MYFATOORAH_URL}/v2/SendPayment', headers=headers, json=data)
    return response.json()

@payments_bp.route('/subscribe')
@login_required
def subscribe_page():
    return render_template('payment.html', banks=['Bank of Khartoum', 'Central Bank of Sudan'])

@payments_bp.route('/create-payment', methods=['POST'])
@login_required
def create_payment():
    method = request.form.get('method')
    amount = 10.0
    payment = Payment(
        user_id=current_user.id,
        amount=amount,
        method=method,
        reference=str(uuid.uuid4()),
        status='pending'
    )
    db.session.add(payment)
    db.session.commit()
    if method == 'myfatoorah' and MYFATOORAH_API_KEY:
        result = create_myfatoorah_invoice(amount, current_user.email, current_user.username, payment.id)
        if 'InvoiceId' in result:
            payment.reference = str(result['InvoiceId'])
            db.session.commit()
            return redirect(result['PaymentURL'])
        flash('Payment gateway error', 'danger')
    elif method == 'bank_transfer':
        flash('Bank transfer request created. Will be activated after confirmation.', 'info')
    return redirect(url_for('payments.subscribe_page'))

@payments_bp.route('/payment-callback')
def payment_callback():
    payment_id = request.args.get('payment_id')
    payment = Payment.query.get(payment_id)
    if payment:
        payment.status = 'completed'
        user = User.query.get(payment.user_id)
        user.subscription_plan = 'pro'
