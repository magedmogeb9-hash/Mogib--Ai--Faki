from flask import Blueprint, render_template, request, jsonify, current_app
from flask_login import login_required, current_user
from subscription import pro_required
from groq import Groq
import os, json

mythos_bp = Blueprint('mythos', __name__, url_prefix='/mythos')
client = Groq(api_key=os.getenv("GROQ_API_KEY"))

@mythos_bp.route('/')
@login_required
@pro_required
def mythos_dashboard():
    """الصفحة الرئيسية لوحدة Mythos (محاكاة لوحة مراقبة الباحث)."""
    return render_template('mythos_dashboard.html')

@mythos_bp.route('/playground', methods=['GET', 'POST'])
@login_required
@pro_required
def mythos_playground():
    """واجهة Playground مع معاملات متقدمة تشبه بيئة المطورين."""
    if request.method == 'POST':
        data = request.json
        system_prompt = data.get('system_prompt', '')
        user_prompt = data.get('user_prompt', '')
        temperature = float(data.get('temperature', 0.7))
        max_tokens = int(data.get('max_tokens', 4096))
        # extended_ththinking وهمي (نمرره كجزء من النظام)
        extended = data.get('extended_thinking', False)
        messages = []
        if system_prompt:
            messages.append({"role": "system", "content": system_prompt + (" [Extended Thinking Mode]" if extended else "")})
        messages.append({"role": "user", "content": user_prompt})
        try:
            response = client.chat.completions.create(
                model="llama3-70b-8192",
                messages=messages,
                temperature=temperature,
                max_tokens=max_tokens,
                stream=False
            )
            answer = response.choices[0].message.content
            return jsonify({"answer": answer})
        except Exception as e:
            return jsonify({"error": str(e)}), 500
    return render_template('mythos_playground.html')

@mythos_bp.route('/artifacts')
@login_required
@pro_required
def mythos_artifacts():
    """عرض الأعمال البرمجية التي ينتجها النموذج (Artifacts)."""
    return render_template('mythos_artifacts.html')

@mythos_bp.route('/upload-large-file', methods=['POST'])
@login_required
@pro_required
def upload_large_file():
    """رفع ملفات ضخمة (حتى 10 ميجابايت) وتحليلها بواسطة النموذج."""
    if 'file' not in request.files:
        return jsonify({"error": "No file provided"}), 400
    file = request.files['file']
    if file.filename == '':
        return jsonify({"error": "Empty filename"}), 400
    content = file.read().decode('utf-8', errors='replace')
    prompt = f"""File: {file.filename}\nContent snippet (first 3000 chars):\n{content[:3000]}\n\nPlease analyze this file, summarize its scientific/technical importance. If code, explain language and purpose."""
    response = client.chat.completions.create(
        model="llama3-70b-8192",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.3
    )
    summary = response.choices[0].message.content
    return jsonify({"filename": file.filename, "summary": summary})
