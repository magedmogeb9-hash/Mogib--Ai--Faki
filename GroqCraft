from flask import Blueprint, request, jsonify, Response, stream_with_context
from flask_login import login_required, current_user
from subscription import pro_required
from utils.scientific_advisor import ScientificAdvisor
from utils.scientific_plot import plot_function
from utils.file_processor import extract_text_from_file
from models import db, ScientificQuery
from groq import Groq
import os, json

api_bp = Blueprint('api', __name__)
client = Groq(api_key=os.getenv("GROQ_API_KEY"))
advisor = ScientificAdvisor(client)

@api_bp.route('/chat', methods=['POST'])
@login_required
def chat():
    data = request.json
    messages = data.get('messages', [])
    def generate():
        stream = client.chat.completions.create(
            model="llama3-70b-8192",
            messages=messages,
            temperature=0.7,
            stream=True
        )
        for chunk in stream:
            if chunk.choices[0].delta.content:
                yield f"data: {json.dumps({'text': chunk.choices[0].delta.content})}\\n\\n"
        yield "data: [DONE]\\n\\n"
    return Response(stream_with_context(generate()), mimetype='text/event-stream')

@api_bp.route('/ask-science', methods=['POST'])
@login_required
@pro_required
def ask_science():
    data = request.json
    question = data.get('question')
    result = advisor.full_scientific_analysis(question, current_user.id)
