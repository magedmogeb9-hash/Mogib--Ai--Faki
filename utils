import json
from groq import Groq
import os

class ScientificAdvisor:
    def __init__(self, groq_client):
        self.client = groq_client

    def detect_scientific_specialty(self, question):
        prompt = f"""Identify the scientific field from: (Physics, Chemistry, Biology, Mathematics, Engineering, Medicine, Pharmacy, Computer Science, Astronomy, Earth Sciences, Energy, Materials, Environment, Agriculture, Nutrition, Neuroscience, Robotics, AI). Answer only the field name.
        Question: {question}"""
        response = self.client.chat.completions.create(model="llama3-70b-8192", messages=[{"role": "user", "content": prompt}], temperature=0.1)
        return response.choices[0].message.content.strip()

    def answer_scientific_question(self, question, specialty):
        prompt = f"""You are a professor in {specialty}. Provide a detailed scientific answer using LaTeX ($$) for equations.
        Question: {question}"""
        response = self.client.chat.completions.create(model="llama3-70b-8192", messages=[{"role": "user", "content": prompt}], temperature=0.3)
        return response.choices[0].message.content

    def develop_ideas(self, question, specialty, answer):
        prompt = f"""Based on the Q&A in {specialty}, develop:
        1. Research project idea
        2. Practical experiment
        3. Innovative tech application
        4. Advanced scientific question
        Output JSON: {{"research_idea":"...","practical_experiment":"...","tech_application":"...","advanced_question":"..."}}"""
        response = self.client.chat.completions.create(model="llama3-70b-8192", messages=[{"role": "user", "content": prompt}], temperature=0.8)
        try:
            return json.loads(response.choices[0].message.content)
        except:
            return {"research_idea": "", "practical_experiment": "", "tech_application": "", "advanced_question": ""}

    def develop_idea_into_project(self, idea, specialty):
        prompt = f"""In {specialty}, turn the idea into a project plan (goal, steps, resources, outcomes):
        Idea: {idea}"""
        response = self.client.chat.completions.create(model="llama3-70b-8192", messages=[{"role": "user", "content": prompt}], temperature=0.6)
        return {"project_plan": response.choices[0].message.content}

    def full_scientific_analysis(self, question, user_id):
        specialty = self.detect_scientific_specialty(question)
        answer = self.answer_scientific_question(question, specialty)
        ideas = self.develop_ideas(question, specialty, answer)
        return {"specialty": specialty, "answer": answer, "developed_ideas": ideas}
