    "GroqCraft/utils/file_processor.py": '''import PyPDF2, docx, pytesseract
from PIL import Image
import io, pandas as pd

def extract_text_from_file(file):
    name = file.filename.lower()
    if name.endswith('.pdf'):
        reader = PyPDF2.PdfReader(file)
        return ' '.join([p.extract_text() for p in reader.pages])
    elif name.endswith('.docx'):
        doc = docx.Document(file)
        return ' '.join([p.text for p in doc.paragraphs])
    elif name.endswith('.txt'):
        return file.read().decode('utf-8')
    elif name.endswith(('.xlsx','.csv')):
        if name.endswith('.csv'):
            df = pd.read_csv(file)
        else:
            df = pd.read_excel(file)
        return df.to_string()
    else:
        return "Unsupported file type"
''',
    "GroqCraft/subscription.py": '''from functools import wraps
from flask import abort
from flask_login import current_user
from datetime import datetime

def pro_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        if not current_user.is_authenticated:
            abort(401)
        if current_user.subscription_plan != 'pro':
            abort(403)
        if current_user.subscription_end and current_user.subscription_end < datetime.utcnow():
            current_user.subscription_plan = 'free'
            from models import db
            db.session.commit()
            abort(403)
        return f(*args, **kwargs)
    return decorated
