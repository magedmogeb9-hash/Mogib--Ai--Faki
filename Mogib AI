from flask_login import login_required, current_user
from models import db, Payment, User
from datetime import datetime, timedelta
import os, uuid
from nowpayments import NOWPayments

crypto_payments_bp = Blueprint('crypto_payments', __name__)
np_client = None

def init_crypto_payment_apis():
    global np_client
    api_key = os.getenv('NOWPAYMENTS_API_KEY')
    if api_key:
        np_client = NOWPayments(api_key=api_key, sandbox=True)
        print("✅ NOWPayments ready")
    else:
        print("⚠️ NOWPayments not configured")

@crypto_payments_bp.route('/crypto/create-payment', methods=['POST'])
@login_required
def create_crypto_payment():
    if not np_client:
        return jsonify({'error': 'Crypto payments not configured'}), 400
    data = request.get_json()
    amount = data.get('amount', 10.0)
    crypto = data.get('crypto_currency', 'usdttrc20')
    try:
        payment = np_client.create_payment(
            price_amount=amount,
            price_currency='usd',
            pay_currency=crypto,
            order_id=f"crypto_{uuid.uuid4().hex[:8]}",
            ipn_callback_url=url_for('crypto_payments.crypto_webhook', _external=True)
        )
        db_payment = Payment(
            user_id=current_user.id,
            amount=amount,
            method=f'crypto_{crypto}',
            reference=payment['payment_id'],
            status='pending'
        )
        db.session.add(db_payment)
        db.session.commit()
        return jsonify({
            'pay_address': payment['pay_address'],
            'pay_amount': payment['pay_amount'],
            'pay_currency': payment['pay_currency'],
            'qr_code': payment.get('qr_code')
        })
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@crypto_payments_bp.route('/crypto/webhook', methods=['POST'])
def crypto_webhook():
    data = request.get_json()
    payment_id = data.get('payment_id')
    status = data.get('payment_status')
    payment = Payment.query.filter_by(reference=str(payment_id)).first()
    if payment and status == 'finished':
        payment.status = 'completed'
        user = User.query.get(payment.user_id)
        user.subscription_plan = 'pro'
        user.subscription_end = datetime.utcnow() + timedelta(days=30)
        db.session.commit()
    return 'OK', 200
