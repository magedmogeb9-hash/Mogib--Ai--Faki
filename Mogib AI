    method = request.form.get('method')
    amount = 10.0
    payment = Payment(
        user_id=current_user.id,
        amount=amount,
        method=method,
        reference=str(uuid.uuid4()),
        status='pending'
    )
    db.session.add(payment)
    db.session.commit()
    if method == 'myfatoorah' and MYFATOORAH_API_KEY:
