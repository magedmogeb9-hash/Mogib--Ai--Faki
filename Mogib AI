import uuid, requests, os

payments_bp = Blueprint('payments', __name__)

MYFATOORAH_API_KEY = os.getenv('MYFATOORAH_API_KEY', '')
MYFATOORAH_MODE = os.getenv('MYFATOORAH_MODE', 'test')
MYFATOORAH_URL = 'https://apitest.myfatoorah.com' if MYFATOORAH_MODE == 'test' else 'https://api.myfatoorah.com'

def create_myfatoorah_invoice(amount, user_email, user_name, payment_id):
    headers = {'Authorization': f'Bearer {MYFATOORAH_API_KEY}', 'Content-Type': 'application/json'}
    data = {
        'CustomerName': user_name,
        'CustomerEmail': user_email,
        'InvoiceValue': amount,
        'DisplayCurrencyIso': 'USD',
        'CallBackUrl': f'http://localhost:5000/payment-callback?payment_id={payment_id}',
        'ErrorUrl': 'http://localhost:5000/payment-error',
        'Language': 'en'
    }
    response = requests.post(f'{MYFATOORAH_URL}/v2/SendPayment', headers=headers, json=data)
    return response.json()

@payments_bp.route('/subscribe')
